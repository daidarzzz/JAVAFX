<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="287.0" prefWidth="322.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pruebafx.SegundaController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <Label text="MANTENIMIENTO DE PERSONAS" />
      <TableView fx:id="personasTableView" prefHeight="178.0" prefWidth="282.0">
        <columns>
          <TableColumn fx:id="nombreTableColumn" prefWidth="75.0" text="Nombre" />
          <TableColumn fx:id="edadTableColumn" prefWidth="75.0" text="Edad" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <TextField fx:id="nombreTextField" promptText="Introducir nombre" />
      <TextField fx:id="edadTextField" promptText="Introduce edad" />
      <Button mnemonicParsing="false" onAction="#guardarButton" text="Guardar" />
      <Button mnemonicParsing="false" onAction="#volverAtrasClickButton" text="Vuelta Atras" />
   </children>


</VBox>
